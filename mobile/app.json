{
  "expo": {
    "name": "FutbolApp",
    "slug": "futbol-app",
    "version": "1.0.0",
    "scheme": "futbolapp",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite seleccionar tu foto de perfil."
        }
      ],
      "expo-location",
      "react-native-map-link"
    ],
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Necesitamos tu ubicación para mostrarte canchas cercanas"
      }
    },
    "android": {
      "package": "com.futbolapp.dev",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0489539b-ec3e-448a-bd1e-68f8bac1f52f"
      }
    }
  }
}
